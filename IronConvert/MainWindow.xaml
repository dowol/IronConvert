<Window x:Class="IronConvert.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IronConvert"
        mc:Ignorable="d"
        Title="IronConvert" Height="450" Width="800">
    <Window.DataContext>
        <local:MainDataContext/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="2"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <DockPanel>
            <DockPanel Height="40" DockPanel.Dock="Top" HorizontalAlignment="Stretch">
                <i:SymbolIcon Symbol="Folder" DockPanel.Dock="Left" Width="40" VerticalAlignment="Center" Margin="5 0"/>
                <Button Command="{Binding ChangeDirectory}" DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal">
                        <i:SymbolIcon Symbol="OpenFolder" VerticalAlignment="Center" Margin="0 0 5 0"/>
                        <AccessText Text="_Change" VerticalAlignment="Center"/> 
                    </StackPanel>
                </Button>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Directory.Name, Mode=OneWay}" FontSize="16"/>
                    <TextBlock FontSize="12" TextTrimming="WordEllipsis" TextWrapping="NoWrap">
                        <Run Text="in" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                        <Run Text="{Binding Directory.Parent.FullName, Mode=OneWay}" TextDecorations="Underline" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
            
            <ListBox ItemsSource="{Binding Items}" 
                     SelectionMode="Single"
                     SelectedValue="{Binding SourceFile}"
                     SelectedIndex="{Binding ListBoxIndex}"
                     SelectionChanged="OnSelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Padding="0 2"
                                   TextWrapping="Wrap">
                                <InlineUIContainer BaselineAlignment="Center">
                                    <Image Source="{Binding FileIcon}" 
                                           Width="20" Height="20" Margin="0"/>
                                </InlineUIContainer>
                                
                                <Run Text="{Binding Name, Mode=OneWay}" BaselineAlignment="Center"/>
                                <InlineUIContainer BaselineAlignment="Center">
                                    <Border CornerRadius="6"
                                            Padding="4 2"
                                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Type}" FontSize="10" />
                                    </Border>
                                </InlineUIContainer>
                            </TextBlock>

                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="5 0"/>
                        <Setter Property="BorderThickness" Value="0 0 0 1"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" />
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1"/>

        <Grid Grid.Column="2" Margin="5 10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Source File:" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            <TextBox Grid.Row="1" Text="{Binding SourceFile.Name, Mode=OneWay}" IsEnabled="False"/>
            <Grid Grid.Row="2" Margin="20 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Padding="4" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SourceFile.Type}"/>
                </Border>
                <i:SymbolIcon Grid.Column="1" Symbol="ArrowRight" Margin="10"/>
                <ComboBox Grid.Column="2" 
                          ItemsSource="{Binding ConvertibleTypes}"
                          SelectedItem="{Binding DestinationType}"
                          SelectedIndex="{Binding DestinationTypeIndex}"
                          SelectionChanged="OnSelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
            <TextBlock Grid.Row="3" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="Convert to:"/>
            <TextBox Grid.Row="4" Text="{Binding DestinationFile.Name}" IsEnabled="False"/>

            <StackPanel Grid.Row="5" Margin="5 10">
                <CheckBox Content="_Open converted file after completed" IsChecked="{Binding OpenWhenConverted}" HorizontalAlignment="Stretch"/>
                <CheckBox Content="_Replace conversion content if destination file already exists" IsChecked="{Binding Overwrite}" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Button Command="{Binding Convert}" Grid.Row="10" Content="_Convert" Margin="20 0" HorizontalAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
